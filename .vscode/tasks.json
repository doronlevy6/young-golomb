{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Torah Scroll Control Panel (Menu)",
      "type": "shell",
      "command": "./scripts/workspace_control_panel.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Torah Scroll Local Preview",
      "type": "shell",
      "command": "npm run local",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy Torah Scroll to GitHub Pages",
      "type": "shell",
      "command": "npm run deploy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
